# 复制本文件为 .env 后填写（cp .env.example .env），切勿用 mv（会丢失模板）。

# ============ 模型 API 凭据（按需填写；默认使用 Claude）============
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ============ 第三方 / 自定义 OpenAI 兼容端点（四要素）============
# 适用于任何兼容 OpenAI Chat Completions 接口的服务（如各类聚合/代理 API、
# 自建网关、月之暗面、智谱、通义、硅基流动、OpenRouter 等）。
OPENAI_COMPAT_LABEL=自定义模型          # Provider 显示名（随意起，便于在界面识别）
OPENAI_COMPAT_BASE_URL=                 # url，如 https://api.example.com/v1
OPENAI_COMPAT_API_KEY=                  # apikey
OPENAI_COMPAT_MODEL=                    # model，如 gpt-4o / qwen-max / glm-4 等
OPENAI_COMPAT_VISION=false              # 该模型能否看图（手写笔记/PDF），能则填 true

# ============ 第三方 Anthropic 兼容中转站（Messages 原生格式）============
# 若你的中转站是 Anthropic Messages 原生格式（不是 OpenAI 格式），用这组。
# 走 anthropic SDK + 自定义 base_url，支持 Claude 系列模型与视觉。
ANTHROPIC_COMPAT_LABEL=Anthropic中转站   # Provider 显示名
ANTHROPIC_COMPAT_BASE_URL=               # url，中转站地址（如 https://xxx.com）
ANTHROPIC_COMPAT_API_KEY=                # apikey（中转站给你的 key）
ANTHROPIC_COMPAT_MODEL=                  # model，如 claude-opus-4-8 / claude-sonnet-4-6
ANTHROPIC_COMPAT_VISION=true             # Claude 系列一般支持看图，填 true

# ============ 默认 Provider 与模型（不填则用 claude）============
# 想默认用中转站，把 DEFAULT_PROVIDER 改成 anthropic_compat；
# 想默认用 OpenAI 兼容端点，改成 openai_compat。
DEFAULT_PROVIDER=claude
# DEFAULT_MODEL=claude-opus-4-8

# 会话数据目录（默认 ../data）
# DATA_DIR=
